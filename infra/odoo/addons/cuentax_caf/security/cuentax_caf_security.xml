<odoo>
    <data noupdate="1">

        <!-- Record rule: multi-company isolation for CAF records -->
        <record id="cuentax_caf_company_rule" model="ir.rule">
            <field name="name">CAF: multi-company</field>
            <field name="model_id" ref="model_cuentax_caf"/>
            <field name="domain_force">[
                '|',
                ('company_id', '=', False),
                ('company_id', 'in', company_ids),
            ]</field>
        </record>

    </data>
</odoo>
