# ============================================================
# GIRAFFOS SII — Variables de Entorno
# Copia este archivo como .env y completa los valores reales
# NUNCA commitear .env al repositorio
# ============================================================

# ----- ODOO 18 -----
ODOO_URL=http://localhost:8069
ODOO_DB=giraffos_sii
ODOO_ADMIN_PASSWORD=changeme_strong_password

# ----- POSTGRESQL (para Odoo) -----
POSTGRES_USER=odoo
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=giraffos_sii
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ----- REDIS -----
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=changeme_redis_password

# ----- BFF (Fastify Node.js) -----
BFF_PORT=4000
NODE_ENV=development
JWT_SECRET=changeme_jwt_secret_min_32_chars_long
JWT_REFRESH_SECRET=changeme_jwt_refresh_secret_min_32
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ----- SII BRIDGE (Python FastAPI) -----
SII_BRIDGE_URL=http://sii-bridge:8001
SII_BRIDGE_PORT=8001
PYTHON_ENV=development

# ----- SII CHILE -----
# Ambiente: certificacion | produccion
SII_AMBIENTE=certificacion
SII_RUT_EMPRESA=12345678-9
SII_RUT_CERT=90000000-6

# URLs SII
SII_URL_CERT=https://maullin.sii.cl
SII_URL_PROD=https://palena.sii.cl
SII_WSDL_CERT=https://maullin.sii.cl/DTEWS/
SII_WSDL_PROD=https://palena.sii.cl/DTEWS/

# ----- CERTIFICADO DIGITAL -----
# Ruta interna del contenedor (montar como volumen secreto)
SII_CERT_PATH=/secrets/certificado.pfx
SII_CERT_PASSWORD=password_del_certificado

# ----- FRONTEND (Next.js) -----
NEXT_PUBLIC_BFF_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Giraffos SII
NEXT_PUBLIC_AMBIENTE=development

# ----- COOLIFY / DEPLOY -----
COOLIFY_WEBHOOK_URL=
COOLIFY_APP_ID=

# ----- MONITORING -----
# Para Sentry (opcional en dev)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
