# CUENTAX — Variables de Entorno
# ================================
# Copia este archivo como .env y completa los valores reales.
# NUNCA commitees el .env con valores reales.

# ── Servidor BFF ─────────────────────────────────────────────
PORT=4000
NODE_ENV=development
LOG_LEVEL=debug

# ── CORS (dominios permitidos, separados por coma) ────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Base de Datos PostgreSQL ──────────────────────────────────
DATABASE_URL=postgresql://cuentax:cuentax@localhost:5432/cuentax

# ── Redis (sesiones, caché, blacklist JWT) ────────────────────
REDIS_URL=redis://localhost:6379

# ── Odoo 18 (back-office ERP) ────────────────────────────────
ODOO_URL=http://localhost:8069
ODOO_DB=cuentax
# Usuario técnico de Odoo (se crea en Configuración → Usuarios)
ODOO_ADMIN_USER=admin
ODOO_ADMIN_PASSWORD=admin

# ── SII Bridge (servicio Python interno) ─────────────────────
SII_BRIDGE_URL=http://localhost:8000/api/v1
# Token secreto compartido entre BFF y SII Bridge
INTERNAL_SECRET=dev_internal_secret_CHANGE_IN_PRODUCTION

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=jwt_super_secret_CHANGE_IN_PRODUCTION_min_32_chars
JWT_REFRESH_SECRET=refresh_super_secret_CHANGE_IN_PRODUCTION_min_32_chars
# Tiempo de expiración (formato: '15m', '1h', '7d')
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# ── SII Bridge (Python ENV) ──────────────────────────────────
# Ambiente SII: 'certificacion' | 'produccion'
SII_AMBIENTE=certificacion
# URLs SOAP (no cambiar salvo instrucción del SII)
SII_CERT_HOST=maullin.sii.cl
SII_PROD_HOST=palena.sii.cl

# ── Frontend (Next.js) ───────────────────────────────────────
# BFF URL visible desde el navegador
NEXT_PUBLIC_BFF_URL=http://localhost:4000
