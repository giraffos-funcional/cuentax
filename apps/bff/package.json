{
  "name": "@cuentax/bff",
  "version": "0.1.0",
  "private": true,
  "description": "CUENTAX BFF — Backend For Frontend (Fastify + TypeScript)",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.87.0",
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@sentry/node": "^10.46.0",
    "axios": "^1.6.8",
    "axios-cookiejar-support": "^6.0.5",
    "bullmq": "^5.71.1",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.1",
    "fast-jwt": "^4.0.5",
    "fastify": "^4.27.0",
    "form-data": "^4.0.5",
    "ioredis": "^5.3.2",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "pino": "^9.0.0",
    "playwright": "^1.59.1",
    "prom-client": "^15.1.3",
    "tesseract.js": "^7.0.0",
    "tough-cookie": "^6.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.20.0",
    "@types/tough-cookie": "^4.0.5",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "@vitest/coverage-v8": "^1.5.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.57.0",
    "pino-pretty": "^11.3.0",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.9.1",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
