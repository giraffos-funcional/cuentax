# CUENTAX — Variables de Entorno PRODUCCIÓN
# ==========================================
# Copia como .env.prod en el servidor y NUNCA commitees con valores reales.
# En Coolify: configurar cada variable en el panel de Environment Variables.

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=cuentax
POSTGRES_USER=cuentax
POSTGRES_PASSWORD=CAMBIAR_PASSWORD_SUPER_SEGURA_32CHARS

DATABASE_URL=postgresql://cuentax:CAMBIAR_PASSWORD_SUPER_SEGURA_32CHARS@postgres:5432/cuentax

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=CAMBIAR_REDIS_PASSWORD_SEGURA
REDIS_URL=redis://:CAMBIAR_REDIS_PASSWORD_SEGURA@redis:6379

# ── JWT ───────────────────────────────────────────────────────
# Generar con: openssl rand -base64 48
JWT_SECRET=CAMBIAR_JWT_SECRET_MIN_48_CHARS_OPENSSL_RAND_BASE64_48
JWT_REFRESH_SECRET=CAMBIAR_REFRESH_SECRET_MIN_48_CHARS_DIFERENTE_AL_ANTERIOR

# ── BFF ───────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
ALLOWED_ORIGINS=https://cuentax.cl,https://www.cuentax.cl
SII_BRIDGE_URL=http://sii-bridge:8000/api/v1
INTERNAL_SECRET=CAMBIAR_INTERNAL_SECRET_COMPARTIDO_BFF_BRIDGE

# ── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_BFF_URL=https://api.cuentax.cl

# ── Odoo ──────────────────────────────────────────────────────
ODOO_URL=http://odoo:8069
ODOO_DB_PASSWORD=cuentax_odoo
ODOO_ADMIN_PASSWORD=CAMBIAR_ODOO_ADMIN_SUPER_SEGURO

# ── SII ───────────────────────────────────────────────────────
SII_AMBIENTE=produccion
# produccion: palena.sii.cl | certificacion: maullin.sii.cl
